# ─────────────────────────────────────────────
# Target Firebase project  (REQUIRED)
# Get these from Firebase Console → Project Settings → Your apps
# ─────────────────────────────────────────────
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=

# ─────────────────────────────────────────────
# Source Firebase project  (REQUIRED for snapshot import only)
# Read-only access to the source inventory project — ask the project owner for these values
# ─────────────────────────────────────────────
REACT_APP_SOURCE_API_KEY=
REACT_APP_SOURCE_AUTH_DOMAIN=
REACT_APP_SOURCE_PROJECT_ID=
REACT_APP_SOURCE_STORAGE_BUCKET=
REACT_APP_SOURCE_MESSAGING_SENDER_ID=
REACT_APP_SOURCE_APP_ID=

# ─────────────────────────────────────────────
# QR code destination URL  (OPTIONAL)
# Override the base URL embedded in generated QR codes.
# Default: https://psrar.github.io/tal_web_app/#/home/items/
# WARNING: changing this after stickers are printed makes existing QR codes invalid.
# ─────────────────────────────────────────────
# REACT_APP_QR_BASE_URL=
